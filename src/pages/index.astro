---
import MetaPage from "@/components/MetaPage.astro"
import Layout from "@/layouts/Layout.astro"
---

<Layout>
  <MetaPage slot="head" />
  <dictionary-entry class="fade-in">
    <header class="entry-header">
      <div class="title-row">
        <h1>mao·kai·he</h1>
        <span class="cursor" aria-hidden="true"></span>
      </div>
      <etymology-span>
        <span class="part-of-speech">dlut student</span>
      </etymology-span>
    </header>

    <ol class="definitions">
      <li data-decrypt-text>
        a software engineering grad student at DUT. knows a bit of Rust and TypeScript, still figuring things out.
      </li>
      <li data-decrypt-text>
        (noun) someone who enjoys open-source software and tweaking dev environments more than is probably healthy.
      </li>
    </ol>
    <hr>
    <prose-content>
      <p data-decrypt-text>
        I mostly write <strong>Rust</strong>, <strong>TypeScript</strong>, and <strong>Python</strong> these days. Switched from Windows to macOS and Linux a while back, and I probably spend too much time configuring my tools instead of actually using them.
      </p>
      <p data-decrypt-text>
        My lab work is mostly industry projects, which means a lot of Java and enterprise stuff. But I still read AI papers now and then — NeurIPS, CVPR, ICLR. Not because I have to, just because it's interesting even when the math goes over my head.
      </p>
      <p data-decrypt-text>
        I try to keep up with the Rust community. RFCs, edition updates, that sort of thing.
        <a href="https://smallcultfollowing.com/babysteps/" target="_blank" rel="noopener noreferrer">Niko Matsakis</a>'
        blog posts and
        <a href="https://www.youtube.com/@Tsoding" target="_blank" rel="noopener noreferrer">Tsoding</a>'s
        streams have probably taught me more about programming than most courses I've taken.
      </p>
      <p data-decrypt-text>
        Thinking about learning Go at some point. Definitely not looking forward to writing more Java than I have to.
      </p>
    </prose-content>
  </dictionary-entry>
</Layout>

<style>
  /* 整体淡入与位移过渡效果 */
  .fade-in {
    animation: entryFadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes entryFadeIn {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  dictionary-entry {
    display: block;
    font-size: var(--step-0);
    color: var(--muted-foreground);

    @media (width >= 64rem) {
      margin-block-start: -0.2em;
    }

    .title-row {
      display: flex;
      align-items: center;
      gap: var(--space-3xs);
    }

    etymology-span {
      opacity: 0.7;
      font-style: italic;
      
      .part-of-speech {
        font-weight: var(--font-weight-normal);
        opacity: 0.8;
      }
    }

    h1 {
      font-size: var(--step-2);
      line-height: calc(var(--leading-offset) + 1em);
      font-weight: var(--font-weight-medium);
      color: var(--foreground);
      margin-block-end: var(--space-3xs);
    }

    ol {
      margin-block-start: var(--space-xs);
      list-style: none;

      li {
        padding-inline-start: 1.2em;
        text-indent: -1.2em;
        transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1), color 0.2s ease;

        &::before {
          content: counter(list-item);
          display: inline-block;
          inline-size: 1.2em;
          text-indent: 0;
          font-weight: var(--font-weight-medium);
        }

        /* 鼠标悬停释义时的微交互 */
        &:hover {
          color: var(--foreground);
          transform: translateX(4px);
        }

        + li {
          margin-block-start: var(--space-3xs);
        }
      }
    }

    hr {
      margin-block: var(--space-m);
      border-block-start: 2px solid var(--border);
    }

    prose-content {
      display: block;
      margin-block-start: var(--space-xs);

      p {
        margin-block-end: var(--space-xs);
        line-height: 1.6;

        strong {
          color: var(--foreground);
          font-weight: var(--font-weight-medium);
        }
      }

      /* 现代感平滑展开的下划线动画 */
      a {
        color: var(--foreground);
        text-decoration: none;
        position: relative;
        transition: color 0.25s ease;

        &::after {
          content: '';
          position: absolute;
          width: 100%;
          transform: scaleX(0);
          height: 1px;
          bottom: -1px;
          left: 0;
          background-color: var(--foreground);
          transform-origin: bottom right;
          transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
        }

        &:hover {
          &::after {
            transform: scaleX(1);
            transform-origin: bottom left;
          }
        }
      }
    }
  }

  [data-decrypt-text] {
    --decrypt-encrypted-color: color-mix(in oklab, var(--muted-foreground) 76%, transparent);
  }

  .decrypt-char {
    display: inline-block;
    text-align: center;
    white-space: pre;
    transition:
      color 0.18s ease,
      opacity 0.18s ease;
  }

  .decrypt-char.is-encrypted {
    color: var(--decrypt-encrypted-color);
  }

  .decrypt-char.is-revealed {
    color: inherit;
  }

  .cursor {
    display: inline-block;
    inline-size: 3px;
    block-size: 1.25em;
    background-color: var(--foreground);
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    50% {
      opacity: 0;
    }
  }
</style>

<script>
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)")

  const defaultDecryptChars =
    "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*+-=?<>"

  const randomChar = (pool) => pool[Math.floor(Math.random() * pool.length)] || "X"

  const revealDecryptText = (root, blockIndex) => {
    const textNodes = []
    const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, {
      acceptNode(node) {
        if (!node.textContent || !node.textContent.trim()) {
          return NodeFilter.FILTER_REJECT
        }
        return NodeFilter.FILTER_ACCEPT
      },
    })

    while (walker.nextNode()) {
      textNodes.push(walker.currentNode)
    }

    if (textNodes.length === 0) return

    const originalChars = []
    for (const node of textNodes) {
      for (const char of Array.from(node.textContent)) {
        if (!/\s/.test(char)) originalChars.push(char)
      }
    }

    const pool = Array.from(new Set(originalChars)).join("") || defaultDecryptChars
    const charSpans = []

    for (const node of textNodes) {
      const fragment = document.createDocumentFragment()

      for (const char of Array.from(node.textContent)) {
        if (/\s/.test(char)) {
          fragment.append(document.createTextNode(char))
          continue
        }

        const span = document.createElement("span")
        span.className = "decrypt-char is-encrypted"
        span.dataset.target = char
        span.textContent = char
        fragment.append(span)
        charSpans.push(span)
      }

      node.parentNode.replaceChild(fragment, node)
    }

    requestAnimationFrame(() => {
      for (const span of charSpans) {
        const width = span.getBoundingClientRect().width
        span.style.inlineSize = `${Math.max(width, 1)}px`
        span.textContent = randomChar(pool)
      }

      let revealed = 0
      const burst = Math.max(1, Math.round(charSpans.length / 36))
      const tickMs = 28
      const startDelay = 140 + blockIndex * 120

      window.setTimeout(() => {
        const runningId = window.setInterval(() => {
          for (let i = revealed; i < charSpans.length; i++) {
            charSpans[i].textContent = randomChar(pool)
          }

          for (let step = 0; step < burst && revealed < charSpans.length; step += 1) {
            const span = charSpans[revealed]
            span.textContent = span.dataset.target
            span.classList.remove("is-encrypted")
            span.classList.add("is-revealed")
            revealed += 1
          }

          if (revealed >= charSpans.length) {
            window.clearInterval(runningId)
          }
        }, tickMs)
      }, startDelay)
    })
  }

  if (!prefersReducedMotion.matches) {
    const blocks = document.querySelectorAll("[data-decrypt-text]")
    blocks.forEach((block, index) => revealDecryptText(block, index))
  }
</script>
