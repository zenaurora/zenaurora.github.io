---
import MetaPage from "@/components/MetaPage.astro"
import Layout from "@/layouts/Layout.astro"
---

<Layout>
  <MetaPage slot="head" />
  <dictionary-entry class="fade-in">
    <header class="entry-header">
      <div class="title-row">
        <h1>mao·kai·he</h1>
        <span class="cursor" aria-hidden="true"></span>
      </div>
      <etymology-span>
        <span class="part-of-speech">dlut student</span>
      </etymology-span>
    </header>

    <ol class="definitions">
      <li>
        a software engineering grad student at DUT. knows a bit of Rust and TypeScript, still figuring things out.
      </li>
      <li>
        (noun) someone who enjoys open-source software and tweaking dev environments more than is probably healthy.
      </li>
    </ol>
    <hr>
    <prose-content>
      <p>
        I mostly write <strong>Rust</strong>, <strong>TypeScript</strong>, and <strong>Python</strong> these days. Switched from Windows to macOS and Linux a while back, and I probably spend too much time configuring my tools instead of actually using them.
      </p>
      <p>
        My lab work is mostly industry projects, which means a lot of Java and enterprise stuff. But I still read AI papers now and then — NeurIPS, CVPR, ICLR. Not because I have to, just because it's interesting even when the math goes over my head.
      </p>
      <p>
        I try to keep up with the Rust community. RFCs, edition updates, that sort of thing.
        <a href="https://smallcultfollowing.com/babysteps/" target="_blank" rel="noopener noreferrer">Niko Matsakis</a>'
        blog posts and
        <a href="https://www.youtube.com/@Tsoding" target="_blank" rel="noopener noreferrer">Tsoding</a>'s
        streams have probably taught me more about programming than most courses I've taken.
      </p>
      <p>
        Thinking about learning Go at some point. Definitely not looking forward to writing more Java than I have to.
      </p>
    </prose-content>


      <article class="activity-card activity-card--panel">
        <div class="activity-heading">
          <span>signal</span>
          <span class="activity-note">last 365 days</span>
        </div>
        <div class="activity-meta">
          <span>steady output</span>
          <span>open source + notes</span>
        </div>
        <div class="activity-cells activity-cells--panel" data-github-activity aria-hidden="true">
          {Array.from({ length: 84 }, () => <i style="--level: 0" />)}
        </div>
        <div class="activity-legend activity-legend--panel" aria-hidden="true">
          <span>less</span>
          {[0, 1, 2, 3, 4].map((level) => <i style={`--level: ${level}`} />)}
          <span>more</span>
        </div>
      </article>
    </section>
  </dictionary-entry>
</Layout>

<style>
  /* 整体淡入与位移过渡效果 */
  .fade-in {
    animation: entryFadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes entryFadeIn {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  dictionary-entry {
    display: block;
    font-size: var(--step-0);
    color: var(--muted-foreground);

    @media (width >= 64rem) {
      margin-block-start: -0.2em;
    }

    .title-row {
      display: flex;
      align-items: center;
      gap: var(--space-3xs);
    }

    etymology-span {
      opacity: 0.7;
      font-style: italic;
      
      .part-of-speech {
        font-weight: var(--font-weight-normal);
        opacity: 0.8;
      }
    }

    h1 {
      font-size: var(--step-2);
      line-height: calc(var(--leading-offset) + 1em);
      font-weight: var(--font-weight-medium);
      color: var(--foreground);
      margin-block-end: var(--space-3xs);
    }

    ol {
      margin-block-start: var(--space-xs);
      list-style: none;

      li {
        padding-inline-start: 1.2em;
        text-indent: -1.2em;
        transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1), color 0.2s ease;

        &::before {
          content: counter(list-item);
          display: inline-block;
          inline-size: 1.2em;
          text-indent: 0;
          font-weight: var(--font-weight-medium);
        }

        /* 鼠标悬停释义时的微交互 */
        &:hover {
          color: var(--foreground);
          transform: translateX(4px);
        }

        + li {
          margin-block-start: var(--space-3xs);
        }
      }
    }

    hr {
      margin-block: var(--space-m);
      border-block-start: 2px solid var(--border);
    }

    prose-content {
      display: block;
      margin-block-start: var(--space-xs);

      p {
        margin-block-end: var(--space-xs);
        line-height: 1.6;

        strong {
          color: var(--foreground);
          font-weight: var(--font-weight-medium);
        }
      }

      /* 现代感平滑展开的下划线动画 */
      a {
        color: var(--foreground);
        text-decoration: none;
        position: relative;
        transition: color 0.25s ease;

        &::after {
          content: '';
          position: absolute;
          width: 100%;
          transform: scaleX(0);
          height: 1px;
          bottom: -1px;
          left: 0;
          background-color: var(--foreground);
          transform-origin: bottom right;
          transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
        }

        &:hover {
          &::after {
            transform: scaleX(1);
            transform-origin: bottom left;
          }
        }
      }
    }
  }

  .activity-compare {
    display: grid;
    gap: var(--space-l);
    margin-block-start: var(--space-xl);
  }

  .activity-card {
    display: block;
    padding-block-start: var(--space-s);
    border-block-start: 1px solid var(--border);
  }

  .activity-card--textured {
    padding-block-start: var(--space-m);
  }

  .activity-card--panel {
    padding: var(--space-s);
    border: 1px solid var(--border);
    border-radius: 14px;
    background: color-mix(in oklab, var(--foreground) 2.5%, transparent);
  }

  .activity-heading,
  .activity-legend,
  .activity-meta {
    display: flex;
    align-items: center;
    color: var(--muted-foreground);
    font-size: var(--step--1);
  }

  .activity-heading {
    justify-content: space-between;
    margin-block-end: var(--space-xs);
  }

  .activity-heading > :first-child {
    color: var(--foreground);
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.01em;
  }

  .activity-note,
  .activity-caption,
  .activity-meta {
    opacity: 0.72;
  }

  .activity-meta {
    justify-content: space-between;
    margin-block-end: var(--space-3xs);
    font-size: 0.72em;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .activity-caption {
    max-inline-size: 38ch;
    margin-block-start: var(--space-xs);
    font-size: var(--step--1);
    line-height: 1.5;
  }

  .activity-cells {
    display: grid;
    grid-template-rows: repeat(6, 1fr);
    grid-auto-flow: column;
    gap: 4px;
    overflow: hidden;
  }

  .activity-cells--minimal {
    gap: 4px;
  }

  .activity-cells--textured {
    gap: 5px;
    padding-block: 2px;
  }

  .activity-cells--panel {
    gap: 3px;
  }

  .activity-cells i,
  .activity-legend i {
    display: block;
    aspect-ratio: 1;
    border-radius: 3px;
    background: color-mix(in oklab, var(--foreground) calc(8% + var(--level) * 16%), transparent);
  }

  .activity-cells i {
    min-inline-size: 8px;
    transition: transform 0.18s ease, background-color 0.18s ease, box-shadow 0.18s ease;
  }

  .activity-card--textured .activity-cells i {
    border-radius: 999px;
  }

  .activity-card--panel .activity-cells i {
    border-radius: 2px;
  }

  .activity-cells i:hover {
    transform: translateY(-1px) scale(1.18);
    background: var(--foreground);
    box-shadow: 0 0 0 1px color-mix(in oklab, var(--foreground) 14%, transparent);
  }

  .activity-legend {
    justify-content: flex-end;
    gap: 4px;
    margin-block-start: var(--space-3xs);
    font-size: 0.7em;
  }

  .activity-legend i {
    inline-size: 8px;
  }

  .activity-legend--panel {
    margin-block-start: var(--space-xs);
  }

  .cursor {
    display: inline-block;
    inline-size: 0.45em;
    block-size: 0.45em;
    margin-inline-start: var(--space-3xs);
    border-radius: 50%;
    background: var(--foreground);
    opacity: 0.72;
    box-shadow: 0 0 0 0.3em color-mix(in oklab, var(--foreground) 9%, transparent);
  }

  @media (prefers-reduced-motion: reduce) {
    .fade-in {
      animation: none;
    }
  }
</style>

<script>
  const username = "zenaurora"
  const grid = document.querySelector("[data-github-activity]")

  if (grid) {
    fetch(`https://github-contributions-api.jogruber.de/v4/${username}?y=last`)
      .then((response) => {
        if (!response.ok) throw new Error("GitHub activity request failed")
        return response.json()
      })
      .then(({ contributions }) => {
        const recent = contributions.slice(-84)
        const grids = document.querySelectorAll("[data-github-activity]")

        grids.forEach((activityGrid) => {
          const cells = activityGrid.querySelectorAll("i")

          cells.forEach((cell, index) => {
            const day = recent[index]
            if (!day) return
            cell.style.setProperty("--level", String(day.level ?? 0))
            cell.title = `${day.date}: ${day.count} contribution${day.count === 1 ? "" : "s"}`
          })
        })
      })
      .catch(() => {
        document.querySelectorAll("[data-github-activity]").forEach((activityGrid) => {
          activityGrid.closest(".activity-card")?.setAttribute("data-unavailable", "")
        })
      })
  }
</script>
