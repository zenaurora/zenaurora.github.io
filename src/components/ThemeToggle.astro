---
import MoonIcon from "@/assets/icons/moon.svg"
import SunIcon from "@/assets/icons/sun.svg"
---

<button id="theme-toggle" aria-label="Toggle theme">
  <light-icon><SunIcon /></light-icon>
  <dark-icon><MoonIcon /></dark-icon>
  <gruvbox-icon>🌲</gruvbox-icon>
  <everforest-icon>🌲</everforest-icon>
  <nord-icon>❄️</nord-icon>
  <blackgold-icon>👑</blackgold-icon>
</button>

<style is:global>
  :root[data-theme="light"] {
    color-scheme: light;
  }

  :root[data-theme="dark"] {
    color-scheme: dark;
  }

  :root[data-theme="gruvbox-dark"] {
    color-scheme: dark;
  }

  :root[data-theme="everforest"] {
    color-scheme: dark;
  }

  :root[data-theme="nord"] {
    color-scheme: dark;
  }

  :root[data-theme="blackgold"] {
    color-scheme: dark;
  }

  light-icon {
    display: inline;
  }

  dark-icon {
    display: none;
  }

  gruvbox-icon {
    display: none;
  }

  everforest-icon {
    display: none;
  }

  nord-icon {
    display: none;
  }

  blackgold-icon {
    display: none;
  }

  :root[data-theme="dark"] {
    light-icon {
      display: none;
    }

    dark-icon {
      display: inline;
    }

    gruvbox-icon {
      display: none;
    }

    everforest-icon {
      display: none;
    }

    nord-icon {
      display: none;
    }

    blackgold-icon {
      display: none;
    }
  }

  :root[data-theme="gruvbox-dark"] {
    light-icon {
      display: none;
    }

    dark-icon {
      display: none;
    }

    gruvbox-icon {
      display: inline;
    }

    everforest-icon {
      display: none;
    }

    nord-icon {
      display: none;
    }

    blackgold-icon {
      display: none;
    }
  }

  :root[data-theme="everforest"] {
    light-icon {
      display: none;
    }

    dark-icon {
      display: none;
    }

    gruvbox-icon {
      display: none;
    }

    everforest-icon {
      display: inline;
    }

    nord-icon {
      display: none;
    }

    blackgold-icon {
      display: none;
    }
  }

  :root[data-theme="nord"] {
    light-icon {
      display: none;
    }

    dark-icon {
      display: none;
    }

    gruvbox-icon {
      display: none;
    }

    everforest-icon {
      display: none;
    }

    nord-icon {
      display: inline;
    }

    blackgold-icon {
      display: none;
    }
  }

  :root[data-theme="blackgold"] {
    light-icon {
      display: none;
    }

    dark-icon {
      display: none;
    }

    gruvbox-icon {
      display: none;
    }

    everforest-icon {
      display: none;
    }

    nord-icon {
      display: none;
    }

    blackgold-icon {
      display: inline;
    }
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme]) {
      light-icon {
        display: none;
      }

      dark-icon {
        display: inline;
      }

      gruvbox-icon {
        display: none;
      }

      everforest-icon {
        display: none;
      }

      nord-icon {
        display: none;
      }

      blackgold-icon {
        display: none;
      }
    }
  }
</style>

<style>
  button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius-md);
    cursor: pointer;

    &:hover {
      background-color: color-mix(in oklab, var(--muted) 50%, transparent);
    }

    svg {
      width: 1rem;
      height: 1rem;
    }

    gruvbox-icon,
    everforest-icon,
    nord-icon,
    blackgold-icon {
      font-size: 1rem;
      line-height: 1;
    }
  }
</style>

<script>
  const themes = ["light", "dark", "gruvbox-dark", "everforest", "nord", "blackgold"]

  const toggleTheme = () => {
    const root = document.documentElement
    const currentTheme = root.dataset.theme || "light"
    const currentIndex = themes.indexOf(currentTheme)
    const nextIndex = (currentIndex + 1) % themes.length
    const nextTheme = themes[nextIndex]

    root.dataset.theme = nextTheme
    localStorage.theme = nextTheme
  }

  const button = document.getElementById("theme-toggle")
  if (button) button.onclick = toggleTheme
</script>
